{
  "name": "omixfit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Omixfit — Hebrew RTL sports class scheduling PWA",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "icons": "node scripts/gen-icons.mjs",
    "fonts": "node scripts/gen-fonts.mjs",
    "shots": "node scripts/shots.mjs",
    "showcase": "node scripts/showcase.mjs",
    "shots:waitlist": "node scripts/shot-waitlist.mjs",
    "a11y": "node scripts/a11y.mjs",
    "focus": "node scripts/focus.mjs",
    "e2e": "node scripts/e2e.mjs",
    "responsive": "node scripts/responsive.mjs",
    "stress": "node scripts/stress.mjs",
    "empty": "node scripts/empty.mjs",
    "lighthouse": "node scripts/lighthouse.mjs",
    "offline": "node scripts/offline.mjs",
    "test": "esbuild test/smoke.ts --bundle --platform=node --format=cjs --outfile=test/smoke.cjs --log-level=error && node test/runner.mjs"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.12.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.12.1",
    "lighthouse": "^12.8.2",
    "puppeteer-core": "^23.11.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
