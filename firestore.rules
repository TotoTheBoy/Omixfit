rules_version = '2';

// OMIX Firestore security rules (Spark / free plan).
//
// Every read/write requires a signed-in user. On top of that we add hardening
// that does NOT depend on a server-verified role (Spark can't do that):
//   • the admin role can never be granted or edited from a client (console-only)
//   • the audit log is append-only (entries can't be altered or deleted)
//   • user/meta docs can't be deleted; unknown paths are denied
//
// LIMITATION: because roles aren't server-verifiable on Spark, these rules can't
// stop a determined *signed-in* user from over-reading or editing data they
// shouldn't (e.g. another member's profile). Full per-role authorization +
// protecting the health forms needs Firebase custom claims, which require the
// Blaze plan + a Cloud Function. See README. When on Blaze, replace the broad
// signed-in writes below with role/ownership checks.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    // The business owners — only these verified emails may hold/grant the admin
    // role (kept in sync with firestore.ts OWNER_EMAILS).
    function isOwnerEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['office@omixfit.com', 'omer@omixfit.com', 'omerido20@gmail.com'];
    }
    // A client may never create or set the admin role…
    function notSettingAdmin() {
      return !('role' in request.resource.data) || request.resource.data.role != 'admin';
    }
    // …nor modify an existing admin account.
    function notEditingAdmin() {
      return resource == null || resource.data.role != 'admin';
    }

    match /users/{uid} {
      allow read: if signedIn();
      // Owners may write admin docs / grant admin; everyone else may not touch
      // the admin role at all.
      allow create: if signedIn() && (notSettingAdmin() || isOwnerEmail());
      allow update: if signedIn()
        && (notSettingAdmin() || isOwnerEmail())
        && (notEditingAdmin() || isOwnerEmail());
      allow delete: if false;
    }

    match /sessions/{id}   { allow read, write: if signedIn(); }
    match /classTypes/{id} { allow read, write: if signedIn(); }
    match /bookings/{id}   { allow read, write: if signedIn(); }
    match /locations/{id}  { allow read, write: if signedIn(); }
    // Revenue data (services + payments). On Blaze these tighten to staff-only.
    match /services/{id}   { allow read, write: if signedIn(); }
    match /payments/{id}   { allow read, write: if signedIn(); }

    // Special events / retreats — events are PUBLIC (marketing + signup page);
    // only staff write them.
    match /events/{id} {
      allow read: if true;
      allow write: if signedIn();
    }
    // Event registrations — PUBLIC create (non-members sign up), staff read/manage.
    // Basic shape validation keeps drive-by writes sane.
    match /eventSignups/{id} {
      allow read, update, delete: if signedIn();
      allow create: if request.resource.data.keys().hasAll(['eventId', 'name', 'phone', 'createdAt'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string && request.resource.data.phone.size() <= 30
        && request.resource.data.eventId is string;
    }
    // Landing leads — PUBLIC create ("just sign up"), staff read/manage.
    match /leads/{id} {
      allow read, update, delete: if signedIn();
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'createdAt'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string && request.resource.data.phone.size() <= 30;
    }

    // Audit log — append-only: created + read, never changed or removed.
    match /audit/{id} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    // Private owner-only billing tracker — only the verified business owners can
    // read or write it (their financial data stays secret from everyone else),
    // yet it still syncs live via Firestore. Must precede the general meta rule.
    match /meta/subscriptions {
      allow read, write: if isOwnerEmail();
    }

    // Google Calendar OAuth refresh token — NO client may read/write it; only
    // the Cloud Functions (admin SDK, which bypasses rules) touch it.
    match /meta/calendar {
      allow read, write: if false;
    }

    // Per-member personal-calendar OAuth refresh tokens — same lockdown: only
    // the Cloud Functions may read/write. Clients never see a refresh token.
    match /calTokens/{uid} {
      allow read, write: if false;
    }

    // Seed marker + facility settings — readable/writable, never deletable.
    // (subscriptions + calendar are excluded above so the line below can't expose them.)
    match /meta/{doc} {
      allow read, create, update: if signedIn() && doc != "subscriptions" && doc != "calendar";
      allow delete: if false;
    }

    // Workout planner — the coach's lesson-plan archive + task reminders (#11).
    match /lessonPlans/{id}   { allow read, write: if signedIn(); }
    match /taskReminders/{id} { allow read, write: if signedIn(); }

    // Anything not matched above is denied.
    match /{document=**} { allow read, write: if false; }
  }
}
